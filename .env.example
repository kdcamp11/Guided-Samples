# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# OpenAI (logo / garment / preview generation — GPT Image 2)
OPENAI_API_KEY=your_openai_api_key

# Replicate — background-removal pipeline (rembg / U²-Net) for logo cleanup.
# Without this token the app falls back to the client-side flood-fill remover.
REPLICATE_API_TOKEN=your_replicate_api_token
# Optional: override the background-removal model (default: 851-labs/background-remover)
# REPLICATE_BG_MODEL=851-labs/background-remover

# Resend (transactional email)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=notifications@yourdomain.com

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
